#!/usr/bin/env python3
"""
arcc-mcp — MCP stdio server wrapping arcc CLI as a tool for Claude Code.

Usage:
  1. Make executable:  chmod +x bin/arcc-mcp
  2. Register in ~/.claude/settings.json (see docs/skills/arcc-cli-skill.md)
  3. Claude Code will have an "arcc" tool available.

Protocol: JSON-RPC 2.0 over stdio (MCP stdio transport).
"""

import json
import subprocess
import sys

ARCC = "arcc"  # or full path like "/usr/local/bin/arcc"

TOOL_DEF = {
    "name": "arcc",
    "description": "Execute shell commands via ARCC AI agent — transforms natural language into shell commands, runs them, and returns results. Useful for system administration, file operations, process management, network diagnostics, git operations, and any terminal task.",
    "inputSchema": {
        "type": "object",
        "properties": {
            "prompt": {
                "type": "string",
                "description": "Task description in natural language (e.g. 'check disk usage', 'list all running processes', 'find large files in /tmp')",
            },
            "unsafe": {
                "type": "boolean",
                "description": "Skip safety allowlist — allow dangerous commands (rm, dd, mkfs, etc.)",
                "default": False,
            },
        },
        "required": ["prompt"],
    },
}


def handle_request(req: dict) -> dict | None:
    method = req.get("method")
    req_id = req.get("id")

    if method == "tools/list":
        return {"jsonrpc": "2.0", "id": req_id, "result": {"tools": [TOOL_DEF]}}

    if method == "tools/call":
        args = req.get("params", {}).get("arguments", {})
        prompt = args.get("prompt", "")
        unsafe = args.get("unsafe", False)

        if not prompt:
            return {
                "jsonrpc": "2.0",
                "id": req_id,
                "error": {"code": -32000, "message": "prompt is required"},
            }

        cmd = [ARCC, "cli", "--json"]
        if unsafe:
            cmd.append("--unsafe")
        cmd.append(prompt)

        try:
            result = subprocess.run(
                cmd, capture_output=True, text=True, timeout=60
            )
            if result.returncode == 0:
                output = result.stdout.strip()
            else:
                output = json.dumps({
                    "response": f"arcc CLI error (exit={result.returncode})",
                    "tool_calls": [],
                    "status": "error",
                })
        except FileNotFoundError:
            output = json.dumps({
                "response": "arcc command not found. Install arcc first.",
                "tool_calls": [],
                "status": "error",
            })
        except subprocess.TimeoutExpired:
            output = json.dumps({
                "response": "arcc CLI timed out after 60 seconds",
                "tool_calls": [],
                "status": "error",
            })

        return {
            "jsonrpc": "2.0",
            "id": req_id,
            "result": {"content": [{"type": "text", "text": output}]},
        }

    # notifications (no id) — ignore
    return None


def main():
    # MCP uses "\n" as message delimiter (newline-delimited JSON)
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            req = json.loads(line)
            resp = handle_request(req)
            if resp is not None:
                sys.stdout.write(json.dumps(resp) + "\n")
                sys.stdout.flush()
        except json.JSONDecodeError:
            continue


if __name__ == "__main__":
    main()
